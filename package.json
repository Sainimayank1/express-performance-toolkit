{
  "name": "express-performance-toolkit",
  "version": "1.0.0",
  "description": "⚡ A powerful Express middleware that automatically optimizes your app with request caching, response compression, slow API detection, and a real-time performance dashboard.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "npm run copy-assets",
    "copy-assets": "mkdir -p dist/dashboard && cp src/dashboard/dashboard.html dist/dashboard/",
    "dev": "tsc --watch",
    "test": "jest --verbose",
    "example": "ts-node example/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "express",
    "performance",
    "middleware",
    "caching",
    "compression",
    "monitoring",
    "dashboard",
    "slow-api",
    "optimization",
    "logging",
    "typescript"
  ],
  "author": "Mayank Saini",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "on-finished": "^2.4.1"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/on-finished": "^2.3.4",
    "@types/supertest": "^7.2.0",
    "express": "^4.21.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}