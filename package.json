{
  "name": "express-performance-toolkit",
  "version": "2.3.1",
  "description": "A powerful Express middleware that automatically optimizes your app with request caching, response compression, slow API detection, and a real-time performance dashboard.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sainimayank1/express-performance-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Sainimayank1/express-performance-toolkit/issues"
  },
  "homepage": "https://github.com/Sainimayank1/express-performance-toolkit#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Sainimayank1"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:ui": "cd dashboard-ui && npm install && npm run build",
    "build": "tsc && npm run build:ui",
    "postbuild": "npm run copy-assets",
    "copy-assets": "rm -rf dist/dashboard-ui && cp -R dashboard-ui/dist dist/dashboard-ui",
    "dev": "tsc --watch",
    "test": "jest --verbose",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "example": "npm run build && ts-node example/server.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "ept",
    "express",
    "performance",
    "middleware",
    "caching",
    "compression",
    "monitoring",
    "dashboard",
    "slow-api",
    "optimization",
    "logging",
    "typescript",
    "ioredis"
  ],
  "author": "Mayank Saini <mayanksaini4455@gmail.com>",
  "contributors": [
    "Mayank Saini <mayanksaini4455@gmail.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "ioredis": "^5.10.1",
    "on-finished": "^2.4.1"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/on-finished": "^2.3.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^4.21.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2"
  }
}
